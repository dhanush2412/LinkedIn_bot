GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
# Apify token for LinkedIn job scraping (free tier at apify.com). Optional —
# only needed for `scrape linkedin`.
APIFY_TOKEN=YOUR_APIFY_TOKEN_HERE
JOBHUNT_DATA_DIR=./data
JOBHUNT_OUTPUT_DIR=./output
JOBHUNT_PROFILE_DIR=./profile
JOBHUNT_SERVER_HOST=127.0.0.1
JOBHUNT_SERVER_PORT=7860
# Optional Google Sheets sync. Leave blank to keep using only the local CSV.
# GOOGLE_SERVICE_ACCOUNT_FILE = path to your service-account JSON key file
# JOBHUNT_SHEET_ID = the spreadsheet ID from its URL (the long string between /d/ and /edit)
GOOGLE_SERVICE_ACCOUNT_FILE=
JOBHUNT_SHEET_ID=
