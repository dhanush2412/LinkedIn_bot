GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
# Apify token for LinkedIn job scraping (free tier at apify.com). Optional —
# only needed for `scrape linkedin`.
APIFY_TOKEN=YOUR_APIFY_TOKEN_HERE
JOBHUNT_DATA_DIR=./data
JOBHUNT_OUTPUT_DIR=./output
JOBHUNT_PROFILE_DIR=./profile
JOBHUNT_SERVER_HOST=127.0.0.1
JOBHUNT_SERVER_PORT=7860
